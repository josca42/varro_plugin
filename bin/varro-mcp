#!/usr/bin/env bash
set -euo pipefail

plugin_root="${VARRO_PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT:-${CODEX_PLUGIN_ROOT:-}}}"

if [[ -z "$plugin_root" ]]; then
  script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
  plugin_root="$(cd -- "$script_dir/.." && pwd)"
fi

if ! command -v uv >/dev/null 2>&1; then
  printf '%s\n' \
    "Varro requires uv, but uv was not found on PATH." \
    "Run the first-use setup in:" \
    "  $plugin_root/INSTALL.md" >&2
  exit 127
fi

exec uv run --project "$plugin_root/server" python -m varro.main
