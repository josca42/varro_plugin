#!/usr/bin/env bash
set -euo pipefail

export PATH="$HOME/.local/bin:$HOME/.cargo/bin:/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:$PATH"

plugin_root="${VARRO_PLUGIN_ROOT:-${CODEX_PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT:-}}}"

if [[ -z "$plugin_root" ]]; then
  script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
  plugin_root="$(cd -- "$script_dir/.." && pwd)"
fi

if ! command -v uv >/dev/null 2>&1; then
  echo "Varro: uv not found on PATH; installing it now..." >&2
  if command -v curl >/dev/null 2>&1; then
    curl -LsSf https://astral.sh/uv/install.sh | sh >&2 || true
  elif command -v wget >/dev/null 2>&1; then
    wget -qO- https://astral.sh/uv/install.sh | sh >&2 || true
  else
    printf '%s\n' \
      "Varro requires uv, but neither curl nor wget is available to install it." \
      "Install uv manually: https://docs.astral.sh/uv/getting-started/installation/" >&2
    exit 127
  fi
  hash -r 2>/dev/null || true
  if ! command -v uv >/dev/null 2>&1; then
    printf '%s\n' \
      "Varro installed uv but it is not yet on PATH." \
      "Restart Codex (or add \$HOME/.local/bin to PATH) and try again." >&2
    exit 127
  fi
fi

project_dir="${VARRO_PROJECT_DIR:-$PWD}"
varro_dir="$project_dir/.varro"
packages_file="${VARRO_PACKAGES_FILE:-$varro_dir/packages.txt}"
package_spec="${VARRO_PACKAGE_SPEC:-varro-mcp}"

mkdir -p "$varro_dir"
export VARRO_PROJECT_DIR="$project_dir"
export UV_CACHE_DIR="${UV_CACHE_DIR:-$varro_dir/uv-cache}"
export MPLCONFIGDIR="${MPLCONFIGDIR:-$varro_dir/matplotlib}"

if [[ -n "${VARRO_SERVER_PROJECT:-}" ]]; then
  uv_args=(run --project "$VARRO_SERVER_PROJECT")
elif [[ "${VARRO_USE_LOCAL_SERVER:-}" == "1" ]]; then
  uv_args=(run --project "$plugin_root/server")
else
  uv_args=(run)
  search_dir="$project_dir"
  while [[ "$search_dir" != "/" ]]; do
    if [[ -f "$search_dir/pyproject.toml" || -f "$search_dir/uv.toml" ]]; then
      uv_args+=(--no-project)
      break
    fi
    search_dir="$(dirname "$search_dir")"
  done
  uv_args+=(--with "$package_spec")
fi

if [[ -s "$packages_file" ]]; then
  uv_args+=(--with-requirements "$packages_file")
fi

exec uv "${uv_args[@]}" varro-mcp
